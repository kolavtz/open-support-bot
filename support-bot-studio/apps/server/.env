PORT=8787

# server auth
EMBED_MASTER_KEY=

# default provider config
DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# example defaults
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
